            <pubDate>Sat, 25 Apr 2026 09:45:01 +0000</pubDate>
            <sparkle:version>7</sparkle:version>
            <sparkle:shortVersionString>0.1.6</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <ul>
                    <li>Drag and drop files between panes to move; hold Cmd or Option to copy.</li>
                    <li>Shift-click and Cmd-click for mouse-based range and multi-selection.</li>
                    <li>Fixed single-click lag caused by double-click gesture disambiguation.</li>
                </ul>
            ]]></description>
